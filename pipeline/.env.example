# ── Anthropic (research / script / title) ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Model used for research + scripting. Default is the most capable model.
# Switch to claude-sonnet-4-6 for lower cost.
PIPELINE_MODEL=claude-opus-4-8
# Let Claude search the web to find real T1–T3 sources (true/false)
PIPELINE_WEB_SEARCH=true

# ── Server ───────────────────────────────────────────────────────────────
PIPELINE_HOST=0.0.0.0
PIPELINE_PORT=8001
# Comma-separated origins allowed to call this API (your GitHub Pages URL).
# "*" allows any origin (fine for local/personal use).
PIPELINE_CORS=*

# ── Output ───────────────────────────────────────────────────────────────
PIPELINE_OUTPUT_DIR=./output

# ── YouTube (upload) ─────────────────────────────────────────────────────
# Path to the OAuth client secrets JSON downloaded from Google Cloud Console
# (APIs & Services → Credentials → OAuth client ID → Desktop app).
YOUTUBE_CLIENT_SECRETS=./client_secret.json
# Where the authorized token is cached after the one-time consent flow.
YOUTUBE_TOKEN_FILE=./youtube_token.json
